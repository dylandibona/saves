# Copy to .env.local and fill in values.

# Supabase — get these from: Supabase dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose to client

# Anthropic — used server-side only for URL classification and enrichment
# If absent, enrichment falls back to OG metadata heuristics (no AI classification).
ANTHROPIC_API_KEY=sk-ant-...

# Inbound email capture domain
# Placeholder — update when final product name and domain are set.
# Format: {username}-{hex}@{INBOUND_EMAIL_DOMAIN}
INBOUND_EMAIL_DOMAIN=in.saves.app

# Google Maps — enable Maps JavaScript API in Google Cloud Console (same project as OAuth)
# Restrict key to your domain + Maps JavaScript API only
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your-maps-api-key

# ── Stripe (gate is currently OPEN — these can be empty in dev) ─────
# Server-side only — secret key for API calls
STRIPE_SECRET_KEY=sk_test_...

# Webhook signing secret from Stripe Dashboard → Webhooks → endpoint signing secret
STRIPE_WEBHOOK_SECRET=whsec_...

# Price IDs from Stripe Dashboard → Products
# Personal: $4/mo (or $36/yr)
STRIPE_PRICE_ID_PERSONAL=price_...
# Household member: $2/mo (invited by a Personal subscriber)
STRIPE_PRICE_ID_HOUSEHOLD_MEMBER=price_...

# Set to 'true' to enforce billing gates (free tier limits + lapsed payment block).
# Default behavior (or any other value) keeps the gate OPEN: all users behave
# as paid. Flip this to switch on enforcement after the paid pricing goes live.
BILLING_ENFORCED=false

# Optional override for absolute URLs in /api/checkout success/cancel redirects.
# Falls back to the request's Origin header, then to the production hostname.
NEXT_PUBLIC_SITE_URL=https://saves.dylandibona.com
